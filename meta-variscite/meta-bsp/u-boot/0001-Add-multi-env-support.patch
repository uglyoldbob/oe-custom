+/*
+ * Check if CRC is valid. Return 0 if CRC is valid
+ */
+int env_check(const char *buf)
+{
+	env_t *ep = (env_t *)buf;
+	uint32_t crc;
+
+	memcpy(&crc, &ep->crc, sizeof(crc));
+
+	if (crc32(0, ep->data, ENV_SIZE) != crc) {
+		return 1;
+	}
+	else {
+		return 0;
+	}
+}
+
 /*
  * Check if CRC is valid and (if yes) import the environment.
  * Note that "buf" may or may not be aligned.
@@ -542,6 +567,144 @@ int env_export(env_t *env_out)
 	return 0;
 }
 
+#ifdef CONFIG_ENV_DUAL_BOOT_ENVIRONMENT
+int compare_rtc_times(struct rtc_time *left, struct rtc_time *right)
+{
+	if (left->tm_year > right->tm_year) {
+		return 1;
+	}
+	else if (left->tm_year < right->tm_year){
+		return 0;
+	}
+	else {
+		//same year
+		if (left->tm_yday > right->tm_yday) {
+			return 1;
+		}
+		else if (left->tm_yday < right->tm_yday) {
+			return 0;
+		}
+		else {
+			//same day
+			if (left->tm_hour > right->tm_hour) {
+				return 1;
+			}
+			else if (left->tm_hour < right->tm_hour) {
+				return 0;
+			}
+			else {
+				//same hour
+				if (left->tm_min > right->tm_min) {
+					return 1;
+				}
+				else if (left->tm_min < right->tm_min) {
+					return 0;
+				}
+				else {
+					//same minute
+					if (left->tm_sec >= right->tm_sec) {
+						return 1;
+					}
+					else
+					{
+						return 0;
+					}
+				}
+			}
+		}
+	}
+}
+
+void env_load_newest_from_fs()
+{
+	int ret;
+	struct blk_desc *fs_dev_desc;
+	struct disk_partition fs_partition;
+	struct fs_dir_stream *dir;
+	__le32 newest_time = 0;
+	char *newest_partition;
+	loff_t current_size, newest_size;
+	char *interface;
+	char *partitions;
+	char *real_partitions;
+	char *partition;
+	char *buffer = NULL;
+	char *new_buffer;
+	loff_t length;
+	char *args[3];
+	char *rootdir = "/environment";
+	__le32 mtime;
+
+	newest_partition = NULL;
+	
+	interface = env_get("interface");
+	//temporary usage of partition in order to make a copy of the environment variable
+	partition = env_get("envpartitions");
+	length = strlen(partition);
+	
+	partitions = malloc(length + 1);
+	real_partitions = partitions;
+	strcpy(partitions, partition);
+	partition = NULL;
+	if (interface != 0) {
+		while( (partition = strsep(&partitions,",")) != NULL )
+		{
+			printf("Check %s\n", partition);
+			args[1] = interface;
+			args[2] = partition;
+			args[3] = rootdir;
+			ret = fs_set_blk_dev(interface, partition, 0);
+			if (ret != 0) {
+				break;
+			}
+			ret = fs_stat(rootdir, &mtime);
+			if (ret != 0) {
+				break;
+			}
+			ret = fs_set_blk_dev(interface, partition, 0);
+			if (ret != 0) {
+				break;
+			}
+			ret = fs_size(rootdir, &current_size);
+			if (ret != 0) {
+				break;
+			}
+			if (mtime > newest_time) {
+				loff_t amount = 0;
+				new_buffer = malloc(current_size);
+				ret = fs_set_blk_dev(interface, partition, 0);
+				ret = fs_read("/environment", (ulong)new_buffer, 0, current_size, &amount);
+				if (ret == 0) {
+					//check for valid environment data in new_buffer
+					if (env_check(new_buffer) == 0) {
+						newest_time = mtime;
+						newest_partition = partition;
+						newest_size = current_size;
+						if (buffer != NULL) {
+							free(buffer);
+						}
+						buffer = new_buffer;
+					}
+				}
+				else {
+					free(new_buffer);
+				}
+			}
+		}
+	}
+
+	if (ret != 0) {
+		free(real_partitions);
+		return;
+	}
+	if (buffer != NULL) {
+		printf("Load from %s\n", newest_partition);
+		env_import(buffer, 0, H_NOCLEAR | H_EXTERNAL);
+	}
+	free(real_partitions);
+}
+#endif
