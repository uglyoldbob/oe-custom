+int do_stat(struct cmd_tbl *cmdtp, int flag, int argc, char *const argv[],
+	  int fstype, __le32 *mtime)
+{
+	if (argc < 2)
+		return CMD_RET_USAGE;
+	if (argc > 4)
+		return CMD_RET_USAGE;
+
+	printf("Fstype is %d\n", fstype);
+	printf("args %s %s\n", argv[1], argv[2]);
+	if (fs_set_blk_dev(argv[1], (argc >= 3) ? argv[2] : NULL, fstype))
+	{
+		printf("fail 1 of do_stat\n");
+		return 1;
+	}
+
+	printf("other args %s\n", argv[3]);
+	if (fs_stat(argc >= 4 ? argv[3] : "/", mtime))
+	{
+		printf("fail 2 of do_stat\n");
+		return 1;
+	}
+	printf("mtime is %d\n", *mtime);
+
+	return 0;
+}
